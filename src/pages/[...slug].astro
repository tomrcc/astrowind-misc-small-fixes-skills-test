---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';

import PageLayout from '~/layouts/PageLayout.astro';
import LandingLayout from '~/layouts/LandingLayout.astro';
import BlockRenderer from '~/components/BlockRenderer.astro';
import type { MetaData } from '~/types';

export const getStaticPaths = (async () => {
  const pages = await getCollection('pages');
  const legal = await getCollection('legal');

  return [
    ...pages.map((entry) => ({
      // `index` collapses to the site root; everything else (incl. `homes/*`,
      // `landing/*`) keeps its nested id as the slug.
      params: { slug: entry.id === 'index' ? undefined : entry.id },
      props: { entry, kind: 'page' as const },
    })),
    ...legal.map((entry) => ({
      params: { slug: entry.id },
      props: { entry, kind: 'legal' as const },
    })),
  ];
}) satisfies GetStaticPaths;

const { entry, kind } = Astro.props;
const data = entry.data as Record<string, unknown>;
const { Content } = await render(entry);

const metadata = {
  title: data.title,
  ...(data.metadata as object | undefined),
} as MetaData;

const layouts = { PageLayout, LandingLayout } as const;
const LayoutComponent = layouts[(data.layout as keyof typeof layouts) || 'PageLayout'] || PageLayout;
const blocks = (data.content_blocks as Array<Record<string, unknown>>) || [];
---

{
  kind === 'legal' ? (
    <PageLayout metadata={metadata}>
      <section class="px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl">
        <h1 class="font-bold font-heading text-4xl md:text-5xl leading-tighter tracking-tighter" data-editable="text" data-prop="title">{data.title}</h1>
        <div
          class="mx-auto prose prose-lg max-w-4xl dark:prose-invert dark:prose-headings:text-slate-300 prose-md prose-headings:font-heading prose-headings:leading-tighter prose-headings:tracking-tighter prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-img:rounded-md prose-img:shadow-lg mt-8"
          data-editable="text"
          data-type="block"
          data-prop="@content"
        >
          <Content />
        </div>
      </section>
    </PageLayout>
  ) : (
    <LayoutComponent metadata={metadata}>
      <div data-editable="array" data-prop="content_blocks" data-component-key="_type">
        {blocks.map((block) => (
          <BlockRenderer block={block} />
        ))}
      </div>
    </LayoutComponent>
  )
}
